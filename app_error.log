[02-Jul-2026 12:48:16 America/Mexico_City] CATALOGO_DEBUG {"page":1,"is_ajax":false,"sql":"SELECT COUNT(DISTINCT p.id_producto) FROM productos p WHERE (p.id_padre IS NULL OR p.id_padre = 0) AND (p.estado = 'activo' OR EXISTS (SELECT 1 FROM productos p_child WHERE p_child.id_padre = p.id_producto AND p_child.estado = 'activo')) AND (p.nombre LIKE :search_name OR p.codigo_barras LIKE :search_code OR p.nombre_variante LIKE :search_variant OR EXISTS (\r\n        SELECT 1 FROM productos p_v \r\n        WHERE p_v.id_padre = p.id_producto \r\n          AND (p_v.nombre LIKE :search_ex OR p_v.codigo_barras LIKE :search_ex_code OR p_v.nombre_variante LIKE :search_ex_variant)\r\n    ))","params":{":search_name":"%omega%",":search_code":"%omega%",":search_variant":"%omega%",":search_ex":"%omega%",":search_ex_code":"%omega%",":search_ex_variant":"%omega%"},"event":"search_count_query","uri":"/e-commerce-pro/views/catalogo.php?search=omega&page=1","ip":"127.0.0.1","client":{"device":"desktop","os":"windows","ua":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/150.0.0.0 Safari/537.36"}}
[02-Jul-2026 12:48:16 America/Mexico_City] CATALOGO_DEBUG {"page":1,"is_ajax":false,"sql":"SELECT p.*,         COALESCE(NULLIF((SELECT pi.ruta_archivo FROM producto_imagenes pi INNER JOIN productos p_img ON pi.id_producto = p_img.id_producto WHERE (p_img.id_producto = p.id_producto OR p_img.id_padre = p.id_producto) ORDER BY (p_img.id_producto = p.id_producto) DESC, pi.orden ASC LIMIT 1), ''), NULLIF(TRIM(p.imagen), ''), NULLIF(TRIM(p.imagen_url), '')) as imagen,        (SELECT MIN(precio_venta) FROM productos p3 WHERE (p3.id_producto = p.id_producto OR p3.id_padre = p.id_producto) AND p3.estado = 'activo') as precio_desde,\r\n        (SELECT COUNT(*) FROM productos p2 WHERE (p2.id_producto = p.id_producto OR p2.id_padre = p.id_producto) AND p2.estado = 'activo') as total_variantes \r\n        FROM productos p WHERE (p.id_padre IS NULL OR p.id_padre = 0) AND (p.estado = 'activo' OR EXISTS (SELECT 1 FROM productos p_child WHERE p_child.id_padre = p.id_producto AND p_child.estado = 'activo')) AND (p.nombre LIKE :search_name OR p.codigo_barras LIKE :search_code OR p.nombre_variante LIKE :search_variant OR EXISTS (\r\n        SELECT 1 FROM productos p_v \r\n        WHERE p_v.id_padre = p.id_producto \r\n          AND (p_v.nombre LIKE :search_ex OR p_v.codigo_barras LIKE :search_ex_code OR p_v.nombre_variante LIKE :search_ex_variant)\r\n    )) ORDER BY p.nombre ASC LIMIT :limit OFFSET :offset","params":{":search_name":"%omega%",":search_code":"%omega%",":search_variant":"%omega%",":search_ex":"%omega%",":search_ex_code":"%omega%",":search_ex_variant":"%omega%",":limit":9,":offset":0},"event":"search_main_query","uri":"/e-commerce-pro/views/catalogo.php?search=omega&page=1","ip":"127.0.0.1","client":{"device":"desktop","os":"windows","ua":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/150.0.0.0 Safari/537.36"}}
